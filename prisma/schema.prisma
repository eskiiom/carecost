generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  firstName        String?
  lastName         String?
  loginAttempts    Int       @default(0)
  lastLoginAttempt DateTime?
  isBlocked        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  role             UserRole  @default(USER)
  preferences      Json?     @default("{\"vehicleViewMode\": \"grid\"}")
  vehicles         Vehicle[]
}

model Vehicle {
  id                   String                @id @default(uuid())
  userId               String
  brand                String
  model                String
  licensePlate         String
  initialMileage       Float?
  powerDIN             Float?
  powerHP              Float?
  batterySize          Float?
  maintenanceFrequency MaintenanceFrequency?
  status               VehicleStatus         @default(ACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  vin                  String
  year                 Int
  lastTechnicalCheck   DateTime?
  nextTechnicalCheck   DateTime?
  energyType           EnergyType
  fuelEntries          FuelEntry[]
  maintenanceEntries   MaintenanceEntry[]
  user                 User                  @relation(fields: [userId], references: [id])

  @@unique([userId, licensePlate])
}

model FuelEntry {
  id                    String        @id @default(uuid())
  vehicleId             String
  date                  DateTime
  mileage               Float
  quantity              Float
  unitPrice             Float
  totalCost             Float
  fuelType              String?
  status                EntryStatus   @default(ACTIVE)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  isSubscription        Boolean       @default(false)
  rechargeType          RechargeType?
  subscriptionEndDate   DateTime?
  subscriptionStartDate DateTime?
  stationType           StationType?
  notes                 String?
  vehicle               Vehicle       @relation(fields: [vehicleId], references: [id])
}

model MaintenanceEntry {
  id           String          @id @default(uuid())
  vehicleId    String
  date         DateTime
  type         MaintenanceType
  description  String
  cost         Float
  mileage      Float
  providerName String?
  status       EntryStatus     @default(ACTIVE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  notes        String?
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id])
}

enum EnergyType {
  GASOLINE
  DIESEL
  GPL
  HYBRID_GASOLINE
  HYBRID_DIESEL
  ELECTRIC
  HYDROGEN
}

enum VehicleStatus {
  ACTIVE
  SOFT_DELETED
}

enum MaintenanceFrequency {
  ANNUAL
  BIENNIAL
  EVERY_15000KM
  EVERY_20000KM
  EVERY_30000KM
}

enum MaintenanceType {
  ROUTINE
  REPAIR
  TECHNICAL_CHECK
  OTHER
  TIRES
}

enum EntryStatus {
  ACTIVE
  SOFT_DELETED
}

enum StationType {
  PUBLIC
  PRIVATE
  HOME
}

enum RechargeType {
  FAST
  NORMAL
  SLOW
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}
