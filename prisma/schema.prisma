generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  firstName        String?
  lastName         String?
  role             UserRole  @default(USER)
  loginAttempts    Int       @default(0)
  lastLoginAttempt DateTime?
  isBlocked        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  vehicles         Vehicle[]
}

model Vehicle {
  id                   String                @id @default(uuid())
  userId               String
  brand                String
  model                String
  licensePlate         String                @unique
  energyType           EnergyType
  chassisNumber        String?
  productionDate       DateTime?
  acquisitionDate      DateTime?
  initialMileage       Float?
  currentMileage       Float?
  powerDIN             Float?
  powerHP              Float?
  batterySize          Float?
  lastTechnicalCheck   DateTime?
  maintenanceFrequency MaintenanceFrequency?
  status               VehicleStatus         @default(ACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  mileage              Int?
  vin                  String?               @unique
  year                 Int
  lastMaintenanceDone  DateTime?
  nextTechnicalCheck   DateTime?
  fuelEntries          FuelEntry[]
  maintenanceEntries   MaintenanceEntry[]
  user                 User                  @relation(fields: [userId], references: [id])
}

model FuelEntry {
  id                   String      @id @default(uuid())
  vehicleId            String
  date                 DateTime
  mileage              Float
  quantity             Float
  unitPrice            Float
  totalCost            Float
  fuelType             String?
  stationType          StationType?
  rechargeType         RechargeType?
  isSubscription       Boolean     @default(false)
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  status               EntryStatus @default(ACTIVE)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  vehicle              Vehicle     @relation(fields: [vehicleId], references: [id])
}

model MaintenanceEntry {
  id           String          @id @default(uuid())
  vehicleId    String
  date         DateTime
  type         MaintenanceType
  description  String
  cost         Float
  mileage      Float
  providerName String?
  status       EntryStatus     @default(ACTIVE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id])
}

enum EnergyType {
  GASOLINE
  DIESEL
  GPL
  HYBRID_GASOLINE
  HYBRID_DIESEL
  ELECTRIC
  HYDROGEN
}

enum VehicleStatus {
  ACTIVE
  SOFT_DELETED
}

enum MaintenanceFrequency {
  ANNUAL
  BIENNIAL
  EVERY_15000KM
  EVERY_20000KM
  EVERY_30000KM
}

enum MaintenanceType {
  ROUTINE
  REPAIR
  TECHNICAL_CHECK
  TIRES
  OTHER
}

enum EntryStatus {
  ACTIVE
  SOFT_DELETED
}

enum StationType {
  PUBLIC
  PRIVATE
  HOME
}

enum RechargeType {
  FAST
  NORMAL
  SLOW
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}
